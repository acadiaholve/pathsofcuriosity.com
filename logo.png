<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8">
<title>PC · Square Logo</title>
<link href='https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@400;500&display=swap' rel='stylesheet'>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{background:#07090f;display:flex;align-items:center;justify-content:center;min-height:100vh;}
</style>
</head><body>
<svg width="0" height="0" style="position:absolute">
  <defs>
    <linearGradient id="sv" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="rgba(232,240,250,0.88)"/>
      <stop offset="100%" stop-color="rgba(192,210,230,0.72)"/>
    </linearGradient>
    <radialGradient id="glowC" cx="54%" cy="44%" r="50%">
      <stop offset="0%"   stop-color="#e8c060" stop-opacity="0.18"/>
      <stop offset="55%"  stop-color="#c8882a" stop-opacity="0.07"/>
      <stop offset="100%" stop-color="#c8882a" stop-opacity="0"/>
    </radialGradient>
    <linearGradient id="goldBar" x1="0" y1="0" x2="928" y2="0" gradientUnits="userSpaceOnUse">
      <stop offset="0%"   stop-color="#e8b84b" stop-opacity="0"/>
      <stop offset="20%"  stop-color="#e8b84b"/>
      <stop offset="50%"  stop-color="#f5d483"/>
      <stop offset="80%"  stop-color="#e8b84b"/>
      <stop offset="100%" stop-color="#e8b84b" stop-opacity="0"/>
    </linearGradient>
  </defs>
</svg>
<div style="background:radial-gradient(ellipse 90% 70% at 55% 22%,#0f38a0 0%,#081e6a 25%,#051248 52%,#020930 78%,#010514 100%);border-radius:20px;width:500px;height:500px;display:flex;align-items:center;justify-content:center;">
  <svg width="420" height="420" viewBox="0 0 500 450" fill="none" overflow="visible">
    <text x="250" y="34" font-family="'Cormorant Garamond',serif" font-size="32" font-weight="500"
      fill="rgba(232,240,250,0.92)" text-anchor="middle" letter-spacing="5">PATHS OF CURIOSITY</text>
    <line x1="50" y1="46" x2="450" y2="46" stroke="rgba(210,225,245,0.52)" stroke-width="0.9"/>
    <g transform="translate(0,58)">
          <ellipse cx="258" cy="138" rx="162" ry="150" fill="url(#glowC)"/>
          <text x="78"  y="248" font-family="'DM Serif Display',serif" font-size="200" fill="url(#sv)" text-anchor="middle" style="opacity:0.78;">P</text>
          <text x="422" y="248" font-family="'DM Serif Display',serif" font-size="200" fill="url(#sv)" text-anchor="middle" style="opacity:0.78;">C</text>
          <image href="data:image/png;base64," x="88" y="-8" width="324" height="324" style="mix-blend-mode:screen; filter:brightness(1.30) contrast(1.14) grayscale(1) sepia(0.20) hue-rotate(-5deg) saturate(1.4);"/>
        </g>
    <line x1="50" y1="382" x2="450" y2="382" stroke="rgba(210,225,245,0.52)" stroke-width="0.9"/>
    <text x="250" y="400" font-family="'DM Mono',monospace" font-size="12"
      fill="rgba(200,220,255,0.82)" text-anchor="middle" letter-spacing="2.2">EXPLORING CAREERS THROUGH THE LENS OF AI</text>
  </svg>
</div>
</body></html>
